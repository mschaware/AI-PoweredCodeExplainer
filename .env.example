# AI-Powered Code Explainer — Environment Configuration
# Copy this file to .env and fill in your API keys
#
# Provider waterfall: Gemini → OpenAI → Claude → Mistral
# The app automatically tries each provider in order.
# You need at least ONE key with active credits for the app to work.

# ─────────────────────────────────────────────────────────────────────────────
# 1. Google Gemini (free tier available)
#    Get your key at: https://aistudio.google.com/app/apikey
# ─────────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# 2. OpenAI (requires billing credits)
#    Get your key at: https://platform.openai.com/api-keys
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# 3. Anthropic Claude (requires billing credits)
#    Get your key at: https://console.anthropic.com/settings/keys
# ─────────────────────────────────────────────────────────────────────────────
CLAUDE_API_KEY=your_claude_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# 4. Mistral AI (free tier available)
#    Get your key at: https://console.mistral.ai/api-keys
# ─────────────────────────────────────────────────────────────────────────────
MISTRAL_API_KEY=your_mistral_api_key_here

# Server port (default: 3000)
PORT=3000
